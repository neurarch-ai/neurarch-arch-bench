\citation{wilson}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Per-family pass rate for \texttt  {claude-sonnet-4-6} on the public benchmark (generator v2; $n{=}12$ per family, all $120$ tasks graded with zero exclusions). Seven families sit at $100\%$ and the convolutional classifier at $83\%$; the two the model finds hard are exactly where verifier-in-the-loop feedback (second column; Section~\ref {sec:amp}) pays off. Overall single-shot $79\%$ (Wilson $95\%$ CI $[71,85]$) rises to $100\%$ ($[97,100]$); the v1-generator measurement ($82\%\to 100\%$, $n{=}117$) replicates within three points.}}{5}{table.2}\protected@file@percent }
\newlabel{tab:perfamily}{{2}{5}{Per-family pass rate for \texttt {claude-sonnet-4-6} on the public benchmark (generator v2; $n{=}12$ per family, all $120$ tasks graded with zero exclusions). Seven families sit at $100\%$ and the convolutional classifier at $83\%$; the two the model finds hard are exactly where verifier-in-the-loop feedback (second column; Section~\ref {sec:amp}) pays off. Overall single-shot $79\%$ (Wilson $95\%$ CI $[71,85]$) rises to $100\%$ ($[97,100]$); the v1-generator measurement ($82\%\to 100\%$, $n{=}117$) replicates within three points}{table.2}{}}
