\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces The same audit with near-miss negatives on generator v2: passing designs one edit from correct ($n{=}60$ each; grok $n{=}51$/$37$ across tiers from provider 503s; corruption mix: dropped component, dropped connection, broken divisibility, each verified to fail). The v1 measurement (FP $22$--$48\%$) replicates. The $0\%$ false-positive rate on blatant negatives collapses to $26$--$47\%$; the model that was perfect on blatant negatives (Qwen) is the worst here, approving whatever looks plausible. LLM judges fail precisely where reward hacking lives; the verifier does not.}}{10}{table.6}\protected@file@percent }
\newlabel{tab:nearmiss}{{6}{10}{The same audit with near-miss negatives on generator v2: passing designs one edit from correct ($n{=}60$ each; grok $n{=}51$/$37$ across tiers from provider 503s; corruption mix: dropped component, dropped connection, broken divisibility, each verified to fail). The v1 measurement (FP $22$--$48\%$) replicates. The $0\%$ false-positive rate on blatant negatives collapses to $26$--$47\%$; the model that was perfect on blatant negatives (Qwen) is the worst here, approving whatever looks plausible. LLM judges fail precisely where reward hacking lives; the verifier does not}{table.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces The collapse, visually: LLM reward models that never approve a blatantly broken design approve $26$--$47\%$ of near-miss designs one edit from correct. The deterministic verifier is $0\%$ on both tiers by construction.}}{10}{figure.7}\protected@file@percent }
\newlabel{fig:nearmiss}{{7}{10}{The collapse, visually: LLM reward models that never approve a blatantly broken design approve $26$--$47\%$ of near-miss designs one edit from correct. The deterministic verifier is $0\%$ on both tiers by construction}{figure.7}{}}
