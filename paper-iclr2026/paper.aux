\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Ablation on the number of verifier-feedback repair rounds, two models (generator v2; claude $n{=}120$, deepseek $n{=}59$; Wilson intervals). For \emph  {both}, a single repair round ($k{=}2$) provides the entire lift -- every task the verifier can help fix is fixed after one round of its failure messages -- and $k{=}3$ adds nothing. The pattern is not model-specific.}}{7}{table.4}\protected@file@percent }
\newlabel{tab:ablation}{{4}{7}{Ablation on the number of verifier-feedback repair rounds, two models (generator v2; claude $n{=}120$, deepseek $n{=}59$; Wilson intervals). For \emph {both}, a single repair round ($k{=}2$) provides the entire lift -- every task the verifier can help fix is fixed after one round of its failure messages -- and $k{=}3$ adds nothing. The pattern is not model-specific}{table.4}{}}
