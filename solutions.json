{
  "_comment": "Reference (oracle) solutions: a known-good action sequence per task. These prove every task is solvable and serve as the upper-bound row in the leaderboard (provider 'reference'). The graded model NEVER sees these; the leaderboard only sends the spec + starting graph. Tests assert each reference passes its own task, so an over-tightened constraint can't slip in unnoticed.",
  "cnn-cifar": [
    {
      "type": "add_component",
      "componentType": "conv2d",
      "name": "conv1",
      "afterName": "input",
      "params": {
        "inChannels": 3,
        "outChannels": 32,
        "kernelSize": 3
      }
    },
    {
      "type": "add_component",
      "componentType": "relu",
      "name": "act1",
      "afterName": "conv1"
    },
    {
      "type": "add_component",
      "componentType": "conv2d",
      "name": "conv2",
      "afterName": "act1",
      "params": {
        "inChannels": 32,
        "outChannels": 64,
        "kernelSize": 3
      }
    },
    {
      "type": "add_component",
      "componentType": "relu",
      "name": "act2",
      "afterName": "conv2"
    },
    {
      "type": "add_component",
      "componentType": "linear",
      "name": "head",
      "afterName": "act2",
      "params": {
        "inFeatures": 64,
        "outFeatures": 10
      }
    }
  ],
  "mlp-tabular": [
    {
      "type": "add_component",
